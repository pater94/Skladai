{
	"appId": "app.vercel.skladai",
	"appName": "SkładAI",
	"webDir": "www",
	"server": {
		"url": "https://skladai.vercel.app",
		"cleartext": true
	},
	"plugins": {
		"Camera": {
			"presentationStyle": "fullScreen"
		},
		"StatusBar": {
			"backgroundColor": "#0a0f0d",
			"style": "DARK"
		},
		"SplashScreen": {
			"backgroundColor": "#0a0f0d",
			"showSpinner": false,
			"launchAutoHide": true,
			"launchShowDuration": 1500
		},
		"SpeechRecognition": {}
	},
	"android": {
		"backgroundColor": "#0a0f0d",
		"allowMixedContent": true,
		"captureInput": true,
		"webContentsDebuggingEnabled": false
	},
	"ios": {
		"backgroundColor": "#0a0f0d",
		"contentInset": "automatic",
		"allowsLinkPreview": false,
		"scrollEnabled": true
	}
}
